# Commit Insights — secrets only
# Create a copy as .env and fill in your keys (not committed to git).
# AI provider/model/baseUrl go in .commit-insights.json, not here.

# OpenAI / OpenAI-compatible (OpenRouter, Azure OpenAI, etc.)
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GOOGLE_API_KEY=...
