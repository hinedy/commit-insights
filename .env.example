# Commit Insights — secrets and overrides
# Create a copy as .env and fill in your values (not committed to git).
# AI provider/model/baseUrl can also go in .commit-insights.json.

# API keys (secrets — never commit):
# OpenAI / OpenAI-compatible (OpenRouter, Azure OpenAI, etc.)
# OPENAI_API_KEY=sk-...
# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# Google Gemini
# GOOGLE_API_KEY=...

# Overrides (use when you want env-level control instead of .commit-insights.json):
# AI_MODEL=gpt-4o
# AI_BASE_URL=https://openrouter.ai/api/v1
# OLLAMA_HOST=http://localhost:11434
