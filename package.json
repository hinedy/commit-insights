{
  "name": "commit-insights",
  "version": "0.1.0",
  "description": "Generate a local git contribution dashboard from commit history",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "commit-insights": "./dist/bin/commit-insights.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/bin/commit-insights.ts",
    "prebuild": "node scripts/vendor-chartjs.mjs",
    "build": "tsup",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "chart.js": "^4.5.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^12.0.0",
    "zod": "^4.4.3"
  }
}
