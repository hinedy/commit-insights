{
  "name": "commit-insights",
  "version": "0.1.0",
  "description": "Generate a local git contribution dashboard from commit history",
  "type": "module",
  "bin": {
    "commit-insights": "./dist/bin/commit-insights.js"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsx src/bin/commit-insights.ts",
    "build": "tsup src/bin/commit-insights.ts src/index.ts --format esm --dts --clean",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  }
}
